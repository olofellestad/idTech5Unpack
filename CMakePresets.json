{
	"version": 8,
	"configurePresets": [
		{
			"displayName": "Base Debug",
            "name": "base-debug",
            "binaryDir": "${sourceDir}/build/${presetName}",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
			},

			"hidden": true
		},

		{
			"displayName": "Base Release",
            "name": "base-release",
            "binaryDir": "${sourceDir}/build/${presetName}",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			},

			"hidden": true
		},

		{
			"displayName": "Windows x64 Debug",
            "name": "windows-x64-debug",
			"generator": "Ninja",
			"inherits": "base-debug",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
		},

		{
			"displayName": "Windows x64 Release",
            "name": "windows-x64-release",
			"generator": "Ninja",
			"inherits": "base-release",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
		},

		{
			"displayName": "MacOS x64 Debug",
            "name": "macos-x64-debug",
			"generator": "Ninja",
			"inherits": "base-debug",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
		},

		{
			"displayName": "MacOS x64 Release",
            "name": "macos-x64-release",
			"generator": "Ninja",
			"inherits": "base-release",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
		}
	]
}
